{
  "name": "ipclaw",
  "version": "1.1.6",
  "description": "CLI-first personal IP growth engine for creators and indie builders.",
  "type": "module",
  "private": true,
  "scripts": {
    "ip:run": "node --import tsx scripts/ipclaw-run.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run format:check",
    "format": "prettier --write \"scripts/**/*.ts\"",
    "format:fix": "prettier --write \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"scripts/**/*.ts\"",
    "build": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  }
}
